# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname?connect_timeout=15

# ── Auth ──────────────────────────────────────────────────────────
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ── Abacus AI Platform ───────────────────────────────────────────
ABACUSAI_API_KEY=
WEB_APP_ID=

# ── Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (test mode)
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_CREATOR_MONTHLY=price_...
STRIPE_PRICE_CREATOR_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_STUDIO_MONTHLY=price_...
STRIPE_PRICE_STUDIO_ANNUAL=price_...
STRIPE_PRICE_TOPUP_1K=price_...
STRIPE_PRICE_TOPUP_3K=price_...
STRIPE_PRICE_TOPUP_8K=price_...
STRIPE_PRICE_TOPUP_20K=price_...

# ── Cloud Storage (AWS S3) ────────────────────────────────────────
AWS_PROFILE=hosted_storage
AWS_REGION=us-west-2
AWS_BUCKET_NAME=
AWS_FOLDER_PREFIX=

# ── AI Providers ──────────────────────────────────────────────────
ELEVENLABS_API_KEY=sk_...
FAL_KEY=

# ── Email (SMTP — Namecheap Private Email) ────────────────────────
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@manifestreelai.com
SMTP_PASS=
ADMIN_EMAIL=admin@manifestreelai.com

# ── Notification IDs (Abacus AI platform) ─────────────────────────
NOTIF_ID_EMAIL_VERIFICATION=
NOTIF_ID_TRIAL_ENDING_SOON=
NOTIF_ID_EMAIL_OTP_VERIFICATION=
NOTIF_ID_SUBSCRIPTION_WELCOME=
NOTIF_ID_PAYMENT_FAILED=
NOTIF_ID_SUBSCRIPTION_CANCELLED=
NOTIF_ID_DISPUTE_ALERT=

# ── Anti-Abuse ────────────────────────────────────────────────────
DEVICE_FP_SALT=generate-unique-salt
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
ABUSE_GATE_RECAPTCHA=off
ABUSE_GATE_IP_SCORING=off

# ── Feature Flags ─────────────────────────────────────────────────
# PRICING_V2=true  # Enable credit-based pricing (Phase 5F)
