generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/manifest_reel_ai/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String?
  avatarUrl     String?   @map("avatar_url")
  role          String    @default("user")
  emailVerified DateTime? @map("email_verified")
  verifyToken   String?   @map("verify_token")
  verifyTokenExpiry DateTime? @map("verify_token_expiry")
  freeReelUsed  Boolean   @default(false) @map("free_reel_used")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  subscription    Subscription?
  usageCounters   UsageCounter[]
  credits         Credit?
  coinPurchases   CoinPurchase[]
  coinRollovers  CoinRollover[]
  analyticsEvents AnalyticsEvent[]
  reels           Reel[]
  generationJobs GenerationJob[]
  socialAccounts SocialAccount[]
  customVoices   CustomVoice[]
  customMusic    CustomMusic[]
  brandPresets   BrandPreset[]
  musicFavorites MusicFavorite[]

  @@map("users")
}

// Premium+ users can favorite library tracks for quick reuse.
model MusicFavorite {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  trackId   String   @map("track_id") // MusicTrack.id (manifest id or v2_<dbid>)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
  @@index([userId])
  @@map("music_favorites")
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique @map("user_id")
  tier                 String   @default("free")
  status               String   @default("active")
  stripeCustomerId     String?  @map("stripe_customer_id")
  stripeSubscriptionId String?  @map("stripe_subscription_id")
  cancelAtPeriodEnd    Boolean  @default(false) @map("cancel_at_period_end")
  trialUsed            Boolean  @default(false) @map("trial_used")
  trialReelsUsed       Int      @default(0)     @map("trial_reels_used")
  trialEndsAt          DateTime? @map("trial_ends_at")
  cardFingerprint      String?   @map("card_fingerprint")
  graceEndsAt          DateTime? @map("grace_ends_at")
  introUsed            Boolean  @default(false) @map("intro_used")
  creditBalance        Int      @default(0) @map("credit_balance")       // V2 credit balance
  scheduledTier        String?  @map("scheduled_tier")                   // V2 downgrade scheduled for next cycle
  isGrandfathered      Boolean  @default(false) @map("is_grandfathered") // Legacy users migrated to V2
  currentPeriodStart   DateTime @default(now()) @map("current_period_start")
  currentPeriodEnd     DateTime @default(dbgenerated("NOW() + interval '30 days'")) @map("current_period_end")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tier])
  @@index([status])
  @@index([createdAt])
  @@map("subscriptions")
}

model UsageCounter {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  reelsUsed   Int      @default(0) @map("reels_used")
  reelsCap    Int      @map("reels_cap")
  tier        String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, periodStart, periodEnd])
  @@map("usage_counters")
}

model Credit {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  balance   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credits")
}

model Reel {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  jobId         String?  @unique @map("job_id")
  prompt        String
  style         String
  platform      String
  voice         String
  mood          String
  title         String?
  scriptJson    Json?    @map("script_json")
  scenesJson    Json?    @map("scenes_json")
  durationSec   Float?   @map("duration_sec")
  motion        Boolean  @default(false)
  coinCost      Int      @default(1) @map("coin_cost")
  caption       String?
  description   String?
  hashtags      String[]
  videoUrl      String?  @map("video_url")
  audioUrl      String?  @map("audio_url")
  thumbnailUrl  String?  @map("thumbnail_url")
  musicUrl      String?  @map("music_url")
  musicTrackId  String?  @map("music_track_id")
  musicSource   String?  @map("music_source")
  tier          String?
  clientIp      String?  @map("client_ip")
  status        String   @default("draft")
  costBreakdown Json?    @map("cost_breakdown")
  totalCost     Float    @default(0) @map("total_cost")
  watermarked   Boolean  @default(true)
  scheduledAt   DateTime? @map("scheduled_at")
  scheduledPlatform String? @map("scheduled_platform")
  brandPresetId String?  @map("brand_preset_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  generationJob  GenerationJob?
  assets         Asset[]
  brandPreset    BrandPreset?    @relation(fields: [brandPresetId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([brandPresetId])
  @@map("reels")
}

model GenerationJob {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  reelId       String?   @unique @map("reel_id")
  status       String    @default("queued")
  currentStep  String?   @map("current_step")
  progressPct  Int       @default(0) @map("progress_pct")
  errorMessage String?   @map("error_message")
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reel Reel? @relation(fields: [reelId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("generation_jobs")
}

model SocialAccount {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  platform              String
  accessTokenEncrypted  String?   @map("access_token_encrypted")
  refreshTokenEncrypted String?   @map("refresh_token_encrypted")
  platformUserId        String?   @map("platform_user_id")
  connectedAt           DateTime  @default(now()) @map("connected_at")
  expiresAt             DateTime? @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@map("social_accounts")
}

model CoinPurchase {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  bundleId          String   @map("bundle_id")
  reelsAdded        Int      @map("reels_added")
  coinsRemaining    Int      @default(0) @map("coins_remaining")
  expiresAt         DateTime? @map("expires_at")
  amountCents       Int      @map("amount_cents")
  stripeSessionId   String?  @map("stripe_session_id")
  status            String   @default("pending")
  createdAt         DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("coin_purchases")
}

model CoinRollover {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  coins     Int      // total rolled-over amount
  remaining Int      // still-available portion (decremented on use)
  fromMonth DateTime @map("from_month") // first day of the source month
  expiresAt DateTime @map("expires_at") // 60 days from creation
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("coin_rollovers")
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  event     String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([event, createdAt])
  @@index([userId])
  @@map("analytics_events")
}

model CustomVoice {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  name             String
  cloudStoragePath String   @map("cloud_storage_path")
  isPublic         Boolean  @default(true) @map("is_public")
  durationSec      Float?   @map("duration_sec")
  source           String   @default("upload")
  createdAt        DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("custom_voices")
}

model CustomMusic {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  name             String
  cloudStoragePath String   @map("cloud_storage_path")
  isPublic         Boolean  @default(true) @map("is_public")
  durationSec      Float?   @map("duration_sec")
  source           String   @default("upload")
  createdAt        DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("custom_music")
}

model BrandPreset {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  name        String
  isDefault   Boolean  @default(false) @map("is_default")
  usageCount  Int      @default(0) @map("usage_count")

  // Brand identity
  logoPath     String?  @map("logo_path")
  logoUrl      String?  @map("logo_url")
  primaryColor String   @default("#D4AF37") @map("primary_color")
  accentColor  String   @default("#7B2FBE") @map("accent_color")

  // Watermark
  watermarkShow     Boolean @default(true) @map("watermark_show")
  watermarkPosition String  @default("bottom-right") @map("watermark_position")
  watermarkOpacity  Int     @default(80) @map("watermark_opacity")
  watermarkSize     String  @default("M") @map("watermark_size")
  watermarkPulse    Boolean @default(false) @map("watermark_pulse")

  // Subject lock: chain scene-1 as visual reference for later scenes (premium quality)
  subjectLock       Boolean @default(true) @map("subject_lock")

  // Subtitle style (full SubtitleStyle JSON)
  subtitleStyle Json? @map("subtitle_style")

  // Voice lock
  voiceId         String? @map("voice_id")
  voiceStability  Float   @default(0.5)  @map("voice_stability")
  voiceSimilarity Float   @default(0.75) @map("voice_similarity")
  voiceTier       String  @default("multilingual") @map("voice_tier")
  clonedVoiceId   String? @map("cloned_voice_id")

  // Music lock
  musicMoods     String[] @map("music_moods")
  musicStyles    String[] @map("music_styles")
  stingerEnabled Boolean  @default(false) @map("stinger_enabled")
  lockedTrackId  String?  @map("locked_track_id")

  // Visual style lock
  modelTier      String  @default("standard") @map("model_tier")
  aspectRatio    String  @default("9:16") @map("aspect_ratio")
  visualKeywords String? @map("visual_keywords")
  motionDefault  Boolean @default(false) @map("motion_default")

  // Metadata defaults
  defaultPlatform String  @default("reels") @map("default_platform")
  defaultLength   Int     @default(25) @map("default_length")
  ctaText         String? @map("cta_text")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reels Reel[]

  @@index([userId])
  @@map("brand_presets")
}

// Per-day aggregate of free-tier generation spend, used to enforce a daily
// budget ceiling and to surface the "Free Tier Budget" widget on /admin/margins.
model DailyFreeStat {
  id          String   @id @default(cuid())
  day         String   @unique // YYYY-MM-DD (UTC)
  spendCents  Int      @default(0) @map("spend_cents")
  reelCount   Int      @default(0) @map("reel_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("daily_free_stats")
}

model Asset {
  id          String   @id @default(cuid())
  reelId      String   @map("reel_id")
  type        String
  url         String
  fileSize    Int?     @map("file_size")
  durationSec Float?   @map("duration_sec")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  reel Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)

  @@index([reelId])
  @@map("assets")
}

// ── Vol. 2 music tracks (uploaded via admin Music Loader) ────────────
model LibraryTrack {
  id            String   @id @default(cuid())
  title         String
  slug          String
  category      String                          // spiritual, luxury, motivational, mysterious, historical, biblical, educated, meditation
  sequence      Int                             // from filename nn
  cloudUrl      String   @map("cloud_url")      // S3 URL of processed (normalized) audio
  originalUrl   String   @map("original_url")   // S3 URL of raw upload
  durationSec   Float    @map("duration_sec")
  bpm           Int?
  mood          String[]                        // derived from category mapping
  style         String[]                        // derived from category mapping
  energy        String   @default("mid")        // low / mid / mid-high / high / very-high
  hasVocals     Boolean  @default(false) @map("has_vocals")
  sizeKb        Int?     @map("size_kb")
  licenseStatus String   @default("royalty_free") @map("license_status") // royalty_free / attribution_required / paid_license / unknown
  source        String   @default("curated_v2")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([category, sequence])
  @@index([category])
  @@index([isActive])
  @@map("library_tracks")
}

// ── Trial abuse prevention locks ────────────────────────────────────
// Lifetime gate: each column is UNIQUE — once consumed, that identity
// can never claim another trial regardless of which account they create.
model TrialLock {
  id              String    @id @default(cuid())
  email           String    @unique
  cardFingerprint String?   @unique @map("card_fingerprint")
  ipAddressHash   String?   @unique @map("ip_address_hash")   // SHA-256 + salt (Phase 5D)
  deviceFpHash    String?   @unique @map("device_fp_hash")
  trialStartedAt  DateTime  @default(now()) @map("trial_started_at")
  trialConsumedAt DateTime? @map("trial_consumed_at")
  trialOutcome    String    @default("PENDING") // PENDING | CONVERTED | CANCELLED | EXPIRED
  reelId          String?   @map("reel_id")     // link to the trial reel record
  subscriptionId  String?   @map("subscription_id")
  supportOverride Boolean   @default(false) @map("support_override")
  overrideReason  String?   @map("override_reason")
  gateResults     Json?     @map("gate_results")      // Full gate decision log (5D)
  recaptchaScore  Float?    @map("recaptcha_score")    // reCAPTCHA v3 score 0.0-1.0
  ipCountry       String?   @map("ip_country")         // ISO country code from IP scoring
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([trialOutcome])
  @@index([ipCountry])
  @@map("trial_locks")
}

// ── Admin IP allowlist (bypass VPN/geo blocks for trusted IPs) ───────
model IpAllowlist {
  id        String   @id @default(cuid())
  ip        String   @unique             // exact IPv4/v6 or CIDR
  label     String?                       // e.g. "Owner home", "Office"
  addedBy   String?  @map("added_by")    // admin userId
  createdAt DateTime @default(now()) @map("created_at")

  @@map("ip_allowlist")
}

// ── Admin-managed blocked email domains ─────────────────────────────
model BlockedDomain {
  id        String   @id @default(cuid())
  domain    String   @unique     // e.g. "mailinator.com" or "card:<fingerprint>"
  source    String   @default("admin") // admin | disposable_list | dispute_block
  reason    String?                     // e.g. "dispute:dp_xxx:user@email"
  createdAt DateTime @default(now()) @map("created_at")

  @@map("blocked_domains")
}

// ── Email OTP codes ─────────────────────────────────────────────────
model EmailOtp {
  id         String   @id @default(cuid())
  email      String
  code       String
  magicToken String?  @unique @map("magic_token")
  attempts   Int      @default(0)
  verified   Boolean  @default(false)
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([email, createdAt])
  @@map("email_otps")
}

// ── Stripe webhook event log (idempotency + audit) ────────────────
model WebhookEvent {
  id              String    @id @default(cuid())
  stripeEventId   String    @unique @map("stripe_event_id")
  eventType       String    @map("event_type")
  payload         Json?
  processedAt     DateTime? @map("processed_at")
  processingError String?   @map("processing_error")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([eventType])
  @@map("webhook_events")
}

// ── Credit ledger (tracks all credit grants/debits for audit) ─────
model CreditLedger {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  amount         Int      // positive=grant, negative=debit
  type           String   // PLAN_GRANT | TOPUP | PRORATION_GRANT | REEL_DEBIT | MIGRATION | REFUND
  description    String?
  subscriptionId String?  @map("subscription_id") // Stripe sub ID if applicable
  stripeEventId  String?  @map("stripe_event_id") // for deduplication
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([stripeEventId])
  @@map("credit_ledger")
}

// ── Rate limiting (durable, DB-backed across serverless instances) ──
// One row per (bucket, identifier). A fixed window starting at windowStart;
// when the window lapses the counter resets on the next hit.
model RateLimit {
  id          String   @id @default(cuid())
  bucket      String   // e.g. "signup", "trial-checkout", "generate-cooldown"
  identifier  String   // IP address or userId
  windowStart DateTime @default(now()) @map("window_start")
  count       Int      @default(0)
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([bucket, identifier])
  @@index([bucket, identifier])
  @@map("rate_limits")
}
